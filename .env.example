# ============================================================
# DeepSeek / Anthropic 兼容后端配置模板
# ============================================================
# 用法：把本文件复制成同目录下的 .env，然后把下面的 key 换成你自己的。
#   PowerShell:  Copy-Item my_cc\.env.example my_cc\.env
# ⚠️ .env 里有你的真实密钥，别提交到 Git / 别发给别人。
#
# 程序启动时（main.py）会自动加载 .env。三个变量都设好后，select_backend()
# 检测到密钥就自动切到真实大模型；删掉/留空密钥则回退到本地 mock。

# Anthropic 兼容端点（DeepSeek 官方提供，基本固定）
ANTHROPIC_BASE_URL = https://api.deepseek.com/anthropic

# ★ 唯一需要你填的：DeepSeek API Key（platform.deepseek.com → API keys 生成）
#   变量名与 DeepSeek 官方文档一致。代码也兼容旧名 ANTHROPIC_AUTH_TOKEN。
ANTHROPIC_API_KEY = 在这里填你的_DeepSeek_key

# 模型名。注意：传入不支持的名字时，DeepSeek 后端会自动映射到 deepseek-v4-flash，
# 不会报错，所以这里填错最多是换了个模型，不会让程序挂掉。
ANTHROPIC_MODEL = deepseek-v4-pro

# 可选：单次回复最大 token 数（代码兜底默认 16384）
ANTHROPIC_MAX_TOKENS = 16384
